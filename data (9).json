            ]
        },
        {
            "id": "tdtBtnCreate",
            "component": "Button",
            "props": {
                "value": "创建",
                "color": "primary",
                "icon": "plus",
                "iconPlacement": "start"
            }
        },
        {
            "id": "tdtBtnDelete",
            "component": "Button",
            "props": {
                "value": "删除",
                "color": "danger",
                "icon": "trash-2",
                "iconPlacement": "start"
            }
        },
        {
            "id": "tdtBtnRefresh",
            "component": "Button",
            "props": {
                "icon": "rotate-cw",
                "shape": "default"
            }
        },
        {
            "id": "tdtTableContainer",
            "component": "div",
            "props": {
                "className": "flex-1 overflow-auto p-gutter"
            },
            "children": [
                "tdtDataTable"
            ]
        },
        {
            "id": "tdtDataTable",
            "component": "Table",
            "props": {
                "rowKey": "id",
                "dataSource": {
                    "path": "/tdtDataSource"
                },
                "columns": {
                    "path": "/tdtTableColumns"
                },
                "rowSelection": {
                    "type": "checkbox",
                    "selectedRowKeys": {
                        "path": "/tdtSelectedKeys"
                    }
                },
                "className": "mb-gutter"
            },
            "children": {
                "path": "/tdtDataSource",
                "componentId": "tdtTableRow"
            }
        },
        {
            "id": "tdtTableRow",
            "component": "TableRow",
            "children": [
                "tdtCellName",
                "tdtCellId",
                "tdtCellCluster",
                "tdtCellFsCount",
                "tdtCellTotalCap",
                "tdtCellUsage",
                "tdtCellAlarm",
                "tdtCellThreshold",
                "tdtCellAction"
            ]
        },
        {
            "id": "tdtCellName",
            "component": "span",
            "props": {
                "value": {
                    "path": "name"
                },
                "className": "text-md font-medium text-primary"
            }
        },
        {
            "id": "tdtCellId",
            "component": "span",
            "props": {
                "value": {
                    "path": "id"
                },
                "className": "text-md text-on-surface-variant"
            }
        },
        {
            "id": "tdtCellCluster",
            "component": "div",
            "props": {
                "className": "flex flex-col gap-1"
            },
            "children": [
                "tdtClusterNode",
                "tdtClusterIp"
            ]
        },
        {
            "id": "tdtClusterNode",
            "component": "div",
            "props": {
                "className": "flex items-center gap-1"
            },
            "children": [
                "tdtClusterNodeText",
                "tdtClusterTag"
            ]
        },
        {
            "id": "tdtClusterNodeText",
            "component": "span",
            "props": {
                "value": {
                    "path": "cluster/node"
                },
                "className": "text-md font-semibold"
            }
        },
        {
            "id": "tdtClusterTag",
            "component": "Tag",
            "props": {
                "value": {
                    "path": "cluster/tag"
                },
                "size": "small",
                "variant": "outlined"
            }
        },
        {
            "id": "tdtClusterIp",
            "component": "span",
            "props": {
                "value": {
                    "path": "cluster/ip"
                },
                "className": "text-sm text-on-surface-variant"
            }
        },
        {
            "id": "tdtCellFsCount",
            "component": "span",
            "props": {
                "value": {
                    "path": "fsCount"
                },
                "className": "text-md"
            }
        },
        {
            "id": "tdtCellTotalCap",
            "component": "span",
            "props": {
                "value": {
                    "path": "totalCap"
                },
                "className": "text-md"
            }
        },
        {
            "id": "tdtCellUsage",
            "component": "div",
            "props": {
                "className": "flex flex-col gap-1 w-full"
            },
            "children": [
                "tdtUsageProgress",
                "tdtUsageDetail"
            ]
        },
        {
            "id": "tdtUsageProgress",
            "component": "Progress",
            "props": {
                "percent": {
                    "path": "usage/percent"
                },
                "size": "small",
                "showInfo": false
            }
        },
        {
            "id": "tdtUsageDetail",
            "component": "span",
            "props": {
                "value": {
                    "path": "usage/detail"
                },
                "className": "text-sm text-on-surface-variant"
            }
        },
        {
            "id": "tdtCellAlarm",
            "component": "div",
            "props": {
                "className": "flex items-center gap-2"
            },
            "children": [
                "tdtAlarmBadge",
                "tdtAlarmText"
            ]
        },
        {
            "id": "tdtAlarmBadge",
            "component": "Badge",
            "props": {
                "status": "success",
                "dot": true
            },
            "children": [
                "tdtAlarmBadgeInner"
            ]
        },
        {
            "id": "tdtAlarmBadgeInner",
            "component": "span",
            "props": {
                "className": "hidden"
            }
        },
        {
            "id": "tdtAlarmText",
            "component": "span",
            "props": {
                "value": {
                    "path": "alarm"
                },
                "className": "text-md"
            }
        },
        {
            "id": "tdtCellThreshold",
            "component": "span",
            "props": {
                "value": {
                    "path": "threshold"
                },
                "className": "text-md"
            }
        },
        {
            "id": "tdtCellAction",
            "component": "div",
            "props": {
                "className": "flex gap-inline"
            },
            "children": [
                "tdtActionDetail",
                "tdtActionMore"
            ]
        },
        {
            "id": "tdtActionDetail",
            "component": "Button",
            "props": {
                "value": "详情",
                "types": "link",
                "size": "small"
            }
        },
        {
            "id": "tdtActionMore",
            "component": "Button",
            "props": {
                "icon": "more-horizontal",
                "types": "link",
                "size": "small"
            }
        }
    ]
}