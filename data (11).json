            "id": "mcaSubTableInstance",
            "component": "Table",
            "props": {
                "rowKey": "ruleId",
                "dataSource": {
                    "path": "subTableData"
                },
                "pagination": false,
                "columns": [
                    {
                        "title": "规则ID",
