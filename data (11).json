            "children": {
                "path": "/mcaSubTabs",
                "componentId": "mcaSubTabItem"
            }
        },
        {
            "id": "mcaSubTabItem",
            "component": "TabItem",
            "props": {
                "key": {
                    "path": "key"
                },
                "label": {
                    "path": "label"
                }
            }
        },
