        {
            "id": "mcaColDest",
            "component": "span",
            "props": {
                "value": {
                    "path": "destIp"
                },
                "className": "font-mono text-sm"
            }
        },
        {
            "id": "mcaColDesc",
            "component": "span",
            "props": {
