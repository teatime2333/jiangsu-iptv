            "props": {
                "className": "p-inline"
            },
            "children": [
                "mcaMainTable"
            ]
        },
        {
            "id": "mcaMainTable",
            "component": "Table",
            "props": {
                "rowKey": "id",
                "dataSource": {
                    "path": "/mcaMainTableData"
                },
                "expandable": {
                    "expandedRowKeys": {
                        "path": "/mcaExpandedRows"
                    }
                },
                "columns": [
                    {
                        "title": "策略类型",
                        "dataIndex": "policyType"
                    },
                    {
                        "title": "源IP地址",
                        "dataIndex": "sourceIp"
                    },
                    {
                        "title": "目的IP地址",
                        "dataIndex": "destIp"
                    },
                    {
                        "title": "描述信息",
                        "dataIndex": "description",
                        "minWidth": "200px"
                    },
                    {
                        "title": "匹配次数",
                        "dataIndex": "matchCount",
                        "align": "center"
                    },
                    {
                        "title": "丢包率",
                        "dataIndex": "lossRate",
                        "align": "right"
                    },
                    {
                        "title": "上行流量",
                        "dataIndex": "upstreamFlow",
                        "align": "right"
                    },
                    {
                        "title": "操作",
                        "dataIndex": "action",
                        "fixed": "end",
                        "width": "120px"
                    }
                ]
            },
            "children": {
                "path": "/mcaMainTableData",
                "componentId": "mcaMainTableRow"
