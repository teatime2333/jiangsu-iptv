                "componentId": "leadTableRow"
            }
        },
        {
            "id": "leadTableRow",
            "component": "TableRow",
            "children": [
                "leadTableNameCell",
                "leadTableSourceCell",
                "leadTableStatusCell",
                "leadTableTimeCell",
                "leadTableScoreCell",
                "leadTableActionsCell"
            ]
        },
        {
            "id": "leadTableNameCell",
            "component": "div",
            "props": {
                "className": "flex items-center gap-3"
            },
            "children": [
                "leadTableNameAvatar",
                "leadTableNameDetails"
            ]
        },
        {
            "id": "leadTableNameAvatar",
            "component": "div",
            "props": {
                "className": "w-9 h-9 rounded-full bg-primary-container flex items-center justify-center shrink-0"
            },
            "children": [
                "leadTableNameAvatarText"
            ]
        },
        {
            "id": "leadTableNameAvatarText",
            "component": "span",
            "props": {
                "value": {
                    "path": "initials"
                },
                "className": "text-xs font-semibold text-primary"
            }
        },
        {
            "id": "leadTableNameDetails",
            "component": "div",
            "props": {
                "className": "flex flex-col min-w-0"
            },
            "children": [
                "leadTableNameFull",
                "leadTableNameCompany"
            ]
        },
        {
            "id": "leadTableNameFull",
            "component": "span",
            "props": {
                "className": "text-sm font-medium text-on-surface truncate"
            },
            "children": [
                "leadTableNameFirst",
                "leadTableNameLast"
            ]
        },
        {
            "id": "leadTableNameFirst",
            "component": "span",
            "props": {
                "value": {
                    "path": "firstName"
                }
            }
        },
        {
            "id": "leadTableNameLast",
            "component": "span",
            "props": {
                "value": {
                    "path": "lastName"
                }
            }
        },
        {
            "id": "leadTableNameCompany",
            "component": "span",
            "props": {
                "value": {
                    "path": "company"
                },
                "className": "text-xs text-on-surface-variant truncate"
            }
        },
        {
            "id": "leadTableSourceCell",
            "component": "div",
            "props": {
                "className": "flex items-center gap-2"
            },
            "children": [
                "leadTableSourceIcon",
                "leadTableSourceText"
            ]
        },
        {
            "id": "leadTableSourceIcon",
            "component": "Icon",
            "props": {
                "name": {
                    "path": "sourceIcon"
                },
                "className": "w-4 h-4 text-on-surface-variant"
            }
        },
        {
            "id": "leadTableSourceText",
            "component": "span",
            "props": {
                "value": {
                    "path": "sourceLabel"
                },
                "className": "text-sm text-on-surface"
            }
        },
        {
            "id": "leadTableStatusCell",
            "component": "Tag",
            "props": {
                "value": {
                    "path": "status"
                },
                "color": "warning",
                "variant": "filled",
                "size": "small"
            }
        },
        {
            "id": "leadTableTimeCell",
            "component": "span",
            "props": {
                "value": {
                    "path": "timeInPool"
                },
                "className": "text-sm text-on-surface"
            }
        },
        {
            "id": "leadTableScoreCell",
            "component": "div",
            "props": {
                "className": "flex items-center gap-2"
            },
            "children": [
                "leadTableScoreProgress",
                "leadTableScoreValue"
            ]
        },
        {
            "id": "leadTableScoreProgress",
            "component": "Progress",
            "props": {
                "percent": {
                    "path": "leadScore"
                },
                "showInfo": false,
                "size": "small",
                "strokeColor": "#0067D1",
                "className": "flex-1"
            }
        },
        {
            "id": "leadTableScoreValue",
            "component": "span",
            "props": {
                "value": {
                    "path": "leadScore"
                },
                "className": "text-sm font-semibold text-on-surface w-8 text-right"
            }
        },
        {
            "id": "leadTableActionsCell",
            "component": "Button",
            "props": {
                "value": "Claim",
                "icon": "user-plus",
                "iconPlacement": "start",
                "types": "link",
                "size": "small",
                "color": "primary"
            }
        },
        {
            "id": "leadTablePaginationInfo",
            "component": "div",
            "props": {
                "className": "flex items-center justify-between px-inset py-stack border-t border-divider"
            },
            "children": [
                "leadTablePaginationText"
            ]
        },
        {
            "id": "leadTablePaginationText",
            "component": "span",
            "props": {
                "value": {
                    "path": "/paginationInfo"
                },
                "className": "text-sm text-on-surface-variant"
            }
        },
        {
            "id": "promoBannerContent",
            "component": "div",
            "props": {
                "className": "flex-1 flex flex-col gap-stack"
            },
            "children": [
                "promoBannerTitle",
                "promoBannerDesc"
            ]
        },
        {
            "id": "promoBannerTitle",
            "component": "h3",
            "props": {
                "className": "text-lg font-semibold text-on-surface",
                "value": {
                    "path": "/title"
                }
            }
        },
        {
            "id": "promoBannerDesc",
            "component": "p",
            "props": {
                "className": "text-sm text-on-surface-variant leading-relaxed max-w-2xl",
                "value": {
                    "path": "/description"
                }
            }
        },
        {
            "id": "promoBannerAction",
            "component": "div",
            "props": {
                "className": "shrink-0"
            },
            "children": [
                "promoBannerUpgradeBtn"
            ]
        },
        {
            "id": "promoBannerUpgradeBtn",
            "component": "Button",
            "props": {
                "value": {
                    "path": "/buttonLabel"
                },
                "icon": {
                    "path": "/buttonIcon"
                },
                "iconPlacement": "end",
                "color": "primary",
                "size": "medium",
                "className": "whitespace-nowrap"
            }
        }
    ]
}