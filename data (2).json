                "dataSource": {
                    "path": "/sliceTableData"
                },
                "className": "px-gutter pb-gutter",
                "columns": [
                    {
                        "title": "切片名称",
                        "dataIndex": "sliceName",
                        "minWidth": 160
                    },
                    {
                        "title": "切片ID",
                        "dataIndex": "sliceId"
                    },
                    {
                        "title": "切片类型",
                        "dataIndex": "sliceType"
                    },
                    {
                        "title": "承载子切片",
                        "dataIndex": "subSlice"
                    },
                    {
                        "title": "承载MTN FG",
                        "dataIndex": "mtnFg"
                    },
                    {
                        "title": "激活状态",
                        "dataIndex": "status",
                        "width": 100
                    },
                    {
                        "title": "链路部署",
                        "dataIndex": "deployment"
                    },
                    {
                        "title": "创建时间",
                        "dataIndex": "createTime",
                        "width": 160
                    },
                    {
                        "title": "修改时间",
                        "dataIndex": "updateTime",
                        "width": 160
                    },
                    {
                        "title": "操作",
                        "dataIndex": "actions",
                        "fixed": "end",
                        "width": 140
                    }
                ]
            },
            "children": {
                "path": "/sliceTableData",
                "componentId": "sliceTableRow"
            }
        },
        {
            "id": "sliceTableRow",
            "component": "TableRow",
            "children": [
                "sliceCellName",
                "sliceCellId",
                "sliceCellType",
                "sliceCellSub",
                "sliceCellMtn",
                "sliceCellStatus",
                "sliceCellDeploy",
                "sliceCellCreate",
                "sliceCellUpdate",
                "sliceCellActions"
            ]
        },
        {
            "id": "sliceCellName",
            "component": "span",
            "props": {
                "value": {
                    "path": "sliceName"
                },
                "className": "font-medium text-primary"
            }
        },
        {
            "id": "sliceCellId",
            "component": "span",
            "props": {
                "value": {
                    "path": "sliceId"
                },
                "className": "text-on-surface-variant"
            }
        },
        {
            "id": "sliceCellType",
            "component": "Tag",
            "props": {
                "value": {
                    "path": "sliceType"
                },
                "variant": "outlined"
            }
        },
        {
            "id": "sliceCellSub",
            "component": "span",
            "props": {
                "value": {
                    "path": "subSlice"
                }
            }
        },
        {
            "id": "sliceCellMtn",
            "component": "span",
            "props": {
                "value": {
                    "path": "mtnFg"
                }
            }
        },
        {
            "id": "sliceCellStatus",
            "component": "Tag",
            "props": {
                "value": {
                    "path": "status"
                },
                "color": {
                    "path": "statusType"
                }
            }
        },
        {
            "id": "sliceCellDeploy",
            "component": "span",
            "props": {
                "value": {
                    "path": "deployment"
                }
            }
        },
        {
            "id": "sliceCellCreate",
            "component": "span",
            "props": {
                "value": {
                    "path": "createTime"
                },
                "className": "text-sm text-on-surface-variant"
            }
        },
        {
            "id": "sliceCellUpdate",
            "component": "span",
            "props": {
                "value": {
                    "path": "updateTime"
                },
                "className": "text-sm text-on-surface-variant"
            }
        },
        {
            "id": "sliceCellActions",
            "component": "div",
            "props": {
                "className": "flex items-center gap-2"
            },
            "children": [
                "sliceBtnEdit",
                "sliceBtnDetail",
                "sliceBtnDownload",
                "sliceBtnDelete"
            ]
        },
        {
            "id": "sliceBtnEdit",
            "component": "Button",
            "props": {
                "icon": "edit",
                "size": "small",
                "color": "default",
                "shape": "circle"
            }
        },
        {
            "id": "sliceBtnDetail",
            "component": "Button",
            "props": {
                "icon": "file-text",
                "size": "small",
                "color": "default",
                "shape": "circle"
            }
        },
        {
            "id": "sliceBtnDownload",
            "component": "Button",
            "props": {
                "icon": "download",
                "size": "small",
                "color": "default",
                "shape": "circle"
            }
        },
        {
            "id": "sliceBtnDelete",
            "component": "Button",
            "props": {
                "icon": "trash-2",
                "size": "small",
                "color": "danger",
                "shape": "circle"
            }
        }
    ]
}