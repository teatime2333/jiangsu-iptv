                    "direction": "horizontal",
                    "xAxis": {
                        "data": "链路名称"
                    },
                    "yAxisTitle": "故障次数",
                    "color": [
                        "#F69E39"
                    ]
                },
                "className": "h-64 w-full mt-stack"
            }
        },
        {
            "id": "nsmCardContainer",
            "component": "div",
            "props": {
                "className": "bg-surface-container-highest shadow-sm rounded-xl p-inset flex flex-col gap-gutter"
            },
            "children": [
                "nsmHeaderRow",
                "nsmToolbarRow",
                "nsmTable"
            ]
        },
        {
            "id": "nsmHeaderRow",
            "component": "div",
            "props": {
                "className": "flex items-center justify-between border-b border-divider pb-stack"
            },
            "children": [
                "nsmCardTitle"
            ]
        },
        {
            "id": "nsmCardTitle",
            "component": "span",
            "props": {
                "className": "text-lg font-bold text-on-surface",
                "value": {
                    "path": "/cardTitle"
                }
            }
        },
        {
            "id": "nsmToolbarRow",
            "component": "div",
            "props": {
                "className": "flex items-center justify-between gap-gutter"
            },
            "children": [
                "nsmSearchInput",
                "nsmBtnGroup"
            ]
        },
        {
            "id": "nsmSearchInput",
            "component": "Input",
            "props": {
                "value": {
                    "path": "/searchVal"
                },
                "placeholder": "搜索切片名称或ID...",
                "prefix": "search",
                "className": "w-80"
            }
        },
        {
            "id": "nsmBtnGroup",
            "component": "div",
            "props": {
                "className": "flex items-center gap-inline"
            },
            "children": [
                "nsmBtnRefresh",
                "nsmBtnExport",
                "nsmBtnAddLink"
            ]
        },
        {
            "id": "nsmBtnRefresh",
            "component": "Button",
            "props": {
                "value": "刷新",
                "icon": "refresh-cw",
                "color": "default",
                "className": "flex items-center"
            }
        },
        {
            "id": "nsmBtnExport",
            "component": "Button",
            "props": {
                "value": "导出",
                "icon": "download",
                "color": "default",
                "className": "flex items-center"
            }
        },
        {
            "id": "nsmBtnAddLink",
            "component": "Button",
            "props": {
                "value": "添加链路",
                "icon": "plus",
                "color": "primary",
                "className": "flex items-center"
            }
        },
        {
            "id": "nsmTable",
            "component": "Table",
            "props": {
                "rowKey": "sliceId",
                "dataSource": {
                    "path": "/tableData"
                },
                "columns": {
                    "path": "/tableColumns"
                },
                "className": "w-full text-md"
            },
            "children": {
                "path": "/tableData",
                "componentId": "nsmTableRow"
            }
        },
        {
            "id": "nsmTableRow",
            "component": "TableRow",
            "children": [
                "nsmCellSliceName",
                "nsmCellSliceId",
                "nsmCellSliceType",
                "nsmCellSubSlice",
                "nsmCellMtnFg",
                "nsmCellStatus",
                "nsmCellDeployment",
                "nsmCellCreateTime",
                "nsmCellUpdateTime",
                "nsmCellActions"
            ]
        },
        {
            "id": "nsmCellSliceName",
            "component": "span",
            "props": {
                "className": "text-md text-on-surface font-medium",
                "value": {
                    "path": "sliceName"
                }
            }
        },
        {
            "id": "nsmCellSliceId",
            "component": "span",
            "props": {
                "className": "text-md text-on-surface-variant font-mono",
                "value": {
                    "path": "sliceId"
                }
            }
        },
        {
            "id": "nsmCellSliceType",
            "component": "Tag",
            "props": {
                "value": {
                    "path": "sliceType"
                },
                "variant": "outlined",
                "className": "text-sm"
            }
        },
        {
            "id": "nsmCellSubSlice",
            "component": "span",
            "props": {
                "className": "text-md text-on-surface-variant",
                "value": {
                    "path": "subSlice"
                }
            }
        },
        {
            "id": "nsmCellMtnFg",
            "component": "span",
            "props": {
                "className": "text-md text-on-surface-variant",
                "value": {
                    "path": "mtnFg"
                }
            }
        },
        {
            "id": "nsmCellStatus",
            "component": "Tag",
            "props": {
                "value": {
                    "path": "status"
                },
                "color": {
                    "path": "statusTagType"
                },
                "variant": "filled",
                "className": "text-sm"
            }
        },
        {
            "id": "nsmCellDeployment",
            "component": "span",
            "props": {
                "className": "text-md text-on-surface-variant max-w-xs truncate block",
                "value": {
                    "path": "deployment"
                },
                "title": {
                    "path": "deployment"
                }
            }
        },
        {
            "id": "nsmCellCreateTime",
            "component": "span",
            "props": {
                "className": "text-md text-on-surface-variant",
                "value": {
                    "path": "createTime"
                }
            }
        },
        {
            "id": "nsmCellUpdateTime",
            "component": "span",
            "props": {
                "className": "text-md text-on-surface-variant",
                "value": {
                    "path": "updateTime"
                }
            }
        },
        {
            "id": "nsmCellActions",
            "component": "div",
            "props": {
                "className": "flex items-center gap-inline"
            },
            "children": [
                "nsmActionEdit",
                "nsmActionFile",
                "nsmActionDownload",
                "nsmActionDelete"
            ]
        },
        {
            "id": "nsmActionEdit",
            "component": "Button",
            "props": {
                "types": "link",
                "icon": "edit-2",
                "color": "primary",
                "size": "small",
                "className": "p-0 min-w-0"
            }
        },
        {
            "id": "nsmActionFile",
            "component": "Button",
            "props": {
                "types": "link",
                "icon": "file-text",
                "color": "default",
                "size": "small",
                "className": "p-0 min-w-0"
            }
        },
        {
            "id": "nsmActionDownload",
            "component": "Button",
            "props": {
                "types": "link",
                "icon": "download",
                "color": "default",
                "size": "small",
                "className": "p-0 min-w-0"
            }
        },
        {
            "id": "nsmActionDelete",
            "component": "Button",
            "props": {
                "types": "link",
                "icon": "trash-2",
                "color": "danger",
                "size": "small",
                "className": "p-0 min-w-0"
            }
        }
    ]
}