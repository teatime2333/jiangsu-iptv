            "children": {
                "path": "/navActions",
                "componentId": "navActionButtonItem"
            }
        },
        {
            "id": "navActionButtonItem",
            "component": "Button",
            "props": {
                "icon": {
                    "path": "icon"
                },
                "title": {
                    "path": "tooltip"
                },
                "shape": "circle",
                "className": "border-none bg-transparent hover:bg-surface-variant text-on-surface-variant flex items-center justify-center w-9 h-9"
            }
        },
        {
            "id": "navUserDropdown",
            "component": "Dropdown",
            "props": {
                "placement": "bottomRight",
                "trigger": [
