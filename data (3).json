            },
            "children": [
                "metCard4Header",
                "metCard4Chart"
            ]
        },
        {
            "id": "metCard4Header",
            "component": "div",
            "props": {
                "className": "flex items-center justify-between"
            },
            "children": [
                "metCard4Title",
                "metCard4Icon"
            ]
        },
        {
            "id": "metCard4Title",
            "component": "span",
            "props": {
                "className": "text-md font-semibold text-on-surface",
                "value": "Top5 故障链路"
            }
        },
        {
            "id": "metCard4Icon",
            "component": "Icon",
            "props": {
                "name": "info",
                "shape": "outline",
                "className": "w-4 h-4 text-on-surface-variant cursor-pointer"
            }
        },
        {
            "id": "metCard4Chart",
            "component": "BarChart",
            "props": {
                "option": {
                    "data": {
                        "path": "/top5FaultLinksData"
                    },
                    "direction": "horizontal",
                    "xAxis": {
                        "data": "链路"
                    },
                    "yAxisTitle": "频次 (次/日)"
                },
                "className": "h-64 w-full"
            }
        },
        {
            "id": "sliHeader",
            "component": "div",
            "props": {
                "className": "flex flex-col gap-stack border-b border-divider pb-stack"
            },
            "children": [
                "sliTitleRow",
                "sliToolbarRow"
            ]
        },
        {
            "id": "sliTitleRow",
            "component": "div",
            "props": {
                "className": "flex items-center justify-between"
            },
            "children": [
                "sliTitle"
            ]
        },
        {
            "id": "sliTitle",
            "component": "span",
            "props": {
                "value": {
                    "path": "/cardTitle"
                },
                "className": "text-lg font-bold text-on-surface"
            }
        },
        {
            "id": "sliToolbarRow",
            "component": "div",
            "props": {
                "className": "flex items-center justify-between gap-gutter"
            },
            "children": [
                "sliSearchInput",
                "sliBtnGroup"
            ]
        },
        {
            "id": "sliSearchInput",
            "component": "Input",
            "props": {
                "value": {
                    "path": "/searchVal"
                },
                "placeholder": {
                    "path": "/toolbar/searchPlaceholder"
                },
                "prefix": "search",
                "className": "w-72"
            }
        },
        {
            "id": "sliBtnGroup",
            "component": "div",
            "props": {
                "className": "flex items-center gap-inline"
            },
            "children": [
                "sliRefreshBtn",
                "sliExportBtn",
                "sliAddBtn"
            ]
        },
        {
            "id": "sliRefreshBtn",
            "component": "Button",
            "props": {
                "icon": "rotate-cw",
                "className": "text-on-surface-variant"
            }
        },
        {
            "id": "sliExportBtn",
            "component": "Button",
            "props": {
                "icon": "download",
                "className": "text-on-surface-variant"
            }
        },
        {
            "id": "sliAddBtn",
            "component": "Button",
            "props": {
                "value": {
                    "path": "/toolbar/addBtnText"
                },
                "icon": "plus",
                "color": "primary"
            }
        },
        {
            "id": "sliTableContainer",
            "component": "div",
            "props": {
                "className": "overflow-x-auto"
            },
            "children": [
                "sliTable"
            ]
        },
        {
            "id": "sliTable",
            "component": "Table",
            "props": {
                "rowKey": "sliceId",
                "dataSource": {
                    "path": "/tableData"
                },
                "columns": {
                    "path": "/tableColumns"
                },
                "className": "mb-4"
            },
            "children": {
                "path": "/tableData",
                "componentId": "sliTableRow"
            }
        },
        {
            "id": "sliTableRow",
            "component": "TableRow",
            "children": [
                "sliCellSliceName",
                "sliCellSliceId",
                "sliCellSliceType",
                "sliCellSubSlice",
                "sliCellMtnFg",
                "sliCellStatus",
                "sliCellDeployment",
                "sliCellCreateTime",
                "sliCellUpdateTime",
                "sliCellActions"
            ]
        },
        {
            "id": "sliCellSliceName",
            "component": "span",
            "props": {
                "value": {
                    "path": "sliceName"
                },
                "className": "font-medium text-on-surface"
            }
        },
        {
            "id": "sliCellSliceId",
            "component": "span",
            "props": {
                "value": {
                    "path": "sliceId"
                },
                "className": "text-xs text-on-surface-variant font-mono"
            }
        },
        {
            "id": "sliCellSliceType",
            "component": "Tag",
            "props": {
                "value": {
                    "path": "sliceType"
                },
                "variant": "outlined"
            }
        },
        {
            "id": "sliCellSubSlice",
            "component": "span",
            "props": {
                "value": {
                    "path": "subSlice"
                },
                "className": "text-on-surface"
            }
        },
        {
            "id": "sliCellMtnFg",
            "component": "span",
            "props": {
                "value": {
                    "path": "mtnFg"
                },
                "className": "text-on-surface font-mono"
            }
        },
        {
            "id": "sliCellStatus",
            "component": "Tag",
            "props": {
                "value": {
                    "path": "status"
                },
                "color": {
                    "path": "statusType"
                }
            }
        },
        {
            "id": "sliCellDeployment",
            "component": "span",
            "props": {
                "value": {
                    "path": "deployment"
                },
                "className": "text-on-surface"
            }
        },
        {
            "id": "sliCellCreateTime",
            "component": "span",
            "props": {
                "value": {
                    "path": "createTime"
                },
                "className": "text-xs text-on-surface-variant"
            }
        },
        {
            "id": "sliCellUpdateTime",
            "component": "span",
            "props": {
                "value": {
                    "path": "updateTime"
                },
                "className": "text-xs text-on-surface-variant"
            }
        },
        {
            "id": "sliCellActions",
            "component": "div",
            "props": {
                "className": "flex items-center gap-inline justify-center"
            },
            "children": {
                "path": "/rowActions",
                "componentId": "sliRowActionBtn"
            }
        },
        {
            "id": "sliRowActionBtn",
            "component": "Button",
            "props": {
                "types": "link",
                "size": "small",
                "icon": {
                    "path": "iconName"
                },
                "title": {
                    "path": "tooltipText"
                },
                "className": "p-1 text-on-surface-variant hover:text-primary"
            }
        }
    ]
}