                "metCard1",
                "metCard2",
                "metCard3",
                "metCard4"
            ]
        },
        {
            "id": "sliceManagementContainer",
            "component": "section",
            "props": {
                "className": "bg-surface-container-highest rounded-container shadow-sm p-inset flex flex-col gap-stack"
