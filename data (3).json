            },
            "children": [
                "navLogoArea",
                "navMenuArea",
                "navActionArea"
            ]
        },
        {
            "id": "mainContentArea",
            "component": "main",
            "props": {
                "className": "flex-1 pt-16 p-gutter flex flex-col gap-gutter"
            },
            "children": [
                "metricsDashboardContainer",
                "sliceManagementContainer"
            ]
        },
        {
            "id": "metricsDashboardContainer",
