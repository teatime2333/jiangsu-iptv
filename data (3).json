        {
            "id": "navLogoIcon",
            "component": "Icon",
            "props": {
                "name": {
                    "path": "/navLogo/icon"
                },
                "color": "primary",
                "className": "w-6 h-6"
            }
        },
        {
            "id": "navLogoText",
            "component": "span",
            "props": {
                "value": {
                    "path": "/navLogo/text"
                },
                "className": "text-lg font-bold text-on-surface"
            }
        },
        {
            "id": "navMenuArea",
            "component": "div",
            "props": {
                "className": "flex items-center gap-6 h-full"
            },
            "children": {
                "path": "/navMenu",
                "componentId": "navMenuItem"
            }
        },
        {
            "id": "navMenuItem",
            "component": "a",
            "props": {
                "href": {
                    "path": "path"
                },
                "className": {
                    "path": "className"
                },
                "value": {
                    "path": "name"
                }
            }
        },
        {
            "id": "navActionArea",
            "component": "div",
            "props": {
                "className": "flex items-center gap-4"
            },
            "children": [
                "navActionButtons",
                "navUserDropdown"
            ]
        },
        {
            "id": "navActionButtons",
            "component": "div",
            "props": {
                "className": "flex items-center gap-2"
